# Copy to .env and fill in real values. NEVER commit .env to git.

# Wiki.js GraphQL endpoint (internal Docker network)
WIKIJS_GRAPHQL_URL=http://wiki:3000/graphql

# Wiki.js service account API token (generate in Wiki.js Admin → API Access)
WIKIJS_SERVICE_TOKEN=

# Postgres connection (internal Docker network)
DATABASE_URL=postgresql://wiki:CHANGEME@db:5432/wiki

# SMTP for notifications and daily digest
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=wiki@example.com
SMTP_PASS=
SMTP_FROM="Firmowe Wiki <wiki@example.com>"

# Public base URL (used in email links)
NEXT_PUBLIC_WIKI_BASE_URL=https://wiki.example.com
