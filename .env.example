# Root .env for Docker Compose. Copy to .env and fill in real values.
# NEVER commit .env to git.

# Postgres password (shared between wiki and nextjs services)
DB_PASSWORD=changeme

# Wiki.js service token (generate in Wiki.js Admin > API Access after first run)
WIKIJS_SERVICE_TOKEN=

# Public domain (Caddy uses this for TLS + routing)
PUBLIC_DOMAIN=wiki.example.com
PUBLIC_URL=https://wiki.example.com

# Azure / Entra ID (for OIDC SSO)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SMTP (for stale notifications and digest)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=wiki@example.com
SMTP_PASS=
SMTP_FROM="Firmowe Wiki <wiki@example.com>"
