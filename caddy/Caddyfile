{$PUBLIC_DOMAIN} {
  # Next.js portal — root and portal-specific routes
  handle /dashboard* {
    reverse_proxy nextjs:3001
  }
  handle /admin/* {
    reverse_proxy nextjs:3001
  }
  handle /report-stale/* {
    reverse_proxy nextjs:3001
  }
  handle /api/graphql-proxy* {
    reverse_proxy nextjs:3001
  }
  handle /_next/* {
    reverse_proxy nextjs:3001
  }
  handle / {
    reverse_proxy nextjs:3001
  }

  # Wiki.js — everything else
  handle {
    reverse_proxy wiki:3000
  }

  # Shared cookie domain — TLS termination here ensures same-origin cookies
  encode gzip
  log {
    output stderr
    format console
  }
}
